{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "buffer.lol",
  "description": "Documentation for the buffer.lol diagnostics toolbox for network, IP, web, and developer checks.",
  "colors": {
    "primary": "#7557E7",
    "light": "#B9A9FF",
    "dark": "#7557E7"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "font": {
    "family": "Inter",
    "headings": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#F7F5FF",
      "dark": "#08080D"
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.buffer.lol"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "quickstart",
          "changelog"
        ]
      },
      {
        "group": "IP Lens",
        "pages": [
          "ip-lens/overview",
          "ip-lens/using-ip-lens",
          "ip-lens/privacy"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/measurements",
          "concepts/privacy"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/overview"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/1337lean/buffer.lol",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@buffer.lol"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open tools",
      "href": "https://buffer.lol/#networking"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/1337lean/buffer.lol"
    }
  }
}
